{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Ejecutar: ig_orchestrator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ig_orchestrator/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "noDebug": true
    },
    {
      "name": "Depurar: ig_orchestrator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ig_orchestrator/main.py",
      "args": [
        "tests"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    }
  ]
}
