{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Ejecutar: GUI ig_orchestrator",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "gui"
      ],
      "noDebug": true
    },
    {
      "name": "Ejecutar: run_continue",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "run_continue",
        "--batch-id",
        "40"
      ],
      "noDebug": true
    },
    {
      "name": "Ejecutar: ig_orchestrator",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "--input",
        "config/batch.json",
        "--run"
      ],
      "noDebug": true
    },
    {
      "name": "Depurar: ig_orchestrator",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "--input",
        "config/batch.json",
        "--run"
      ]
    },
    {
      "name": "Depurar: run_continue",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "run_continue"
      ]
    },
    {
      "name": "Depurar: dry-run batch",
      "type": "debugpy",
      "request": "launch",
      "module": "ig_orchestrator",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "--input",
        "config/batch.json",
        "--dry-run"
      ]
    },
    {
      "name": "Tests: pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "false"
      },
      "args": [
        "tests"
      ],
      "noDebug": true
    }
  ]
}
